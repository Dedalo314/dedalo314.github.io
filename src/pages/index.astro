---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="MathPhysicsAI | Frontiers of Thought">
  <section
    class="relative min-h-[60vh] flex flex-col justify-center items-center text-center py-12 sm:py-20 overflow-hidden"
  >
    <!-- Background glow/gradient -->
    <div class="absolute inset-0 z-0 pointer-events-none">
      <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-64 sm:w-96 h-64 sm:h-96 bg-blue-600/20 rounded-full blur-[80px] sm:blur-[100px]"
      >
      </div>
      <div
        class="absolute top-1/4 right-1/4 w-48 sm:w-64 h-48 sm:h-64 bg-indigo-600/10 rounded-full blur-[60px] sm:blur-[80px]"
      >
      </div>
    </div>

    <div class="relative z-10 space-y-6 sm:space-y-8 max-w-3xl mx-auto px-4 sm:px-6">
      <div
        class="inline-flex items-center px-3 py-1 text-xs sm:text-sm font-medium border border-blue-500/20 bg-blue-500/10 text-blue-600 dark:text-blue-400 rounded-full animate-fade-in"
      >
        Explore Mathematics, Physics, and AI
      </div>
      <h1
        class="text-5xl sm:text-6xl md:text-7xl font-extrabold tracking-tight text-gray-900 dark:text-white animate-slide-up"
      >
        Decoding the <span
          class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-indigo-500"
          >Frontiers</span
        >
      </h1>
      <p
        class="text-lg sm:text-xl text-gray-600 dark:text-gray-400 leading-relaxed font-sans max-w-2xl mx-auto animate-fade-in delay-200"
      >
        A deep dive into the underlying principles of the universe and the
        intelligence that strives to understand it.
      </p>
      <div
        class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-6 animate-fade-in delay-400 w-full"
      >
        <a
          href="/blog"
          class="w-full sm:w-auto group relative px-8 py-4 bg-blue-600 dark:bg-white text-white dark:text-black font-bold rounded-xl overflow-hidden transition-all hover:scale-105 shadow-lg shadow-blue-500/25 text-center"
        >
          <span class="relative z-10">Explore the Blog</span>
          <div
            class="absolute inset-0 bg-gradient-to-r from-blue-700 to-indigo-700 dark:from-blue-100 dark:to-indigo-100 opacity-0 group-hover:opacity-100 transition-opacity"
          >
          </div>
        </a>
        <a
          href="/about"
          class="w-full sm:w-auto px-8 py-4 border border-gray-200 dark:border-gray-800 text-gray-600 dark:text-gray-300 font-semibold rounded-xl hover:bg-gray-50 dark:hover:bg-gray-900 transition-all text-center"
        >
          Learn More
        </a>
      </div>
    </div>
  </section>

  <!-- Featured Topics Section -->
  <section class="py-12 sm:py-24 border-t border-gray-100 dark:border-gray-900">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 sm:gap-12 px-4 sm:px-0">
      <div class="space-y-4">
        <div
          class="w-12 h-12 bg-blue-100 dark:bg-blue-900/30 rounded-lg flex items-center justify-center text-blue-600 dark:text-blue-400 text-2xl font-bold"
        >
          ∑
        </div>
        <h3 class="text-xl font-bold text-gray-900 dark:text-white">
          Mathematics
        </h3>
        <p class="text-gray-600 dark:text-gray-500 leading-relaxed">
          From abstract structures to fundamental theorems, exploring the
          language of nature.
        </p>
      </div>
      <div class="space-y-4">
        <div
          class="w-12 h-12 bg-indigo-100 dark:bg-indigo-900/30 rounded-lg flex items-center justify-center text-indigo-600 dark:text-indigo-400 text-2xl font-bold"
        >
          ℏ
        </div>
        <h3 class="text-xl font-bold text-gray-900 dark:text-white">Physics</h3>
        <p class="text-gray-600 dark:text-gray-500 leading-relaxed">
          Understanding the fundamental forces and particles that shape our
          reality.
        </p>
      </div>
      <div class="space-y-4">
        <div
          class="w-12 h-12 bg-emerald-100 dark:bg-emerald-900/30 rounded-lg flex items-center justify-center text-emerald-600 dark:text-emerald-400 text-2xl font-bold"
        >
          🧠
        </div>
        <h3 class="text-xl font-bold text-gray-900 dark:text-white">
          AI & Agents
        </h3>
        <p class="text-gray-600 dark:text-gray-500 leading-relaxed">
          The architecture of intelligence and the evolution of synthetic minds.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  @keyframes fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
  @keyframes slide-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-in {
    animation: fade-in 1s ease-out forwards;
  }
  .animate-slide-up {
    animation: slide-up 0.8s ease-out forwards;
  }
  .delay-200 {
    animation-delay: 0.2s;
  }
  .delay-400 {
    animation-delay: 0.4s;
  }
</style>
