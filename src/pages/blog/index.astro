---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const allTags = [
  ...new Set(posts.flatMap((post) => post.data.tags || [])),
].sort();
---

<BaseLayout title="Blog | MathPhysicsAI">
  <section class="max-w-4xl mx-auto py-12 sm:py-20 space-y-12 sm:space-y-16">
    <header class="text-center space-y-4 sm:space-y-6">
      <div
        class="inline-flex items-center px-3 py-1 text-[10px] sm:text-xs font-semibold uppercase tracking-widest border border-blue-500/20 bg-blue-500/10 text-blue-600 dark:text-blue-400 rounded-full mb-2 sm:mb-4"
      >
        Writing & Insights
      </div>
      <h1
        class="text-4xl sm:text-5xl md:text-6xl font-extrabold tracking-tight text-gray-900 dark:text-white"
      >
        Insights from the <span
          class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-indigo-500"
          >Frontiers</span
        >
      </h1>
      <p
        class="mt-4 text-lg sm:text-xl text-gray-600 dark:text-gray-500 max-w-2xl mx-auto leading-relaxed px-4"
      >
        Thoughts, theories, and explorations in mathematics, physics, and AI.
      </p>

      {
        allTags.length > 0 && (
          <div class="flex flex-wrap justify-center gap-2 pt-8">
            <button
              class="tag-filter active px-4 py-1.5 rounded-full text-sm font-medium transition-all border border-gray-200 dark:border-gray-800 hover:border-blue-500/50 bg-white dark:bg-gray-900 text-gray-600 dark:text-gray-400"
              data-tag="all"
            >
              All Posts
            </button>
            {allTags.map((tag) => (
              <button
                class="tag-filter px-4 py-1.5 rounded-full text-sm font-medium transition-all border border-gray-200 dark:border-gray-800 hover:border-blue-500/50 bg-white dark:bg-gray-900 text-gray-600 dark:text-gray-400"
                data-tag={tag}
              >
                {tag}
              </button>
            ))}
          </div>
        )
      }
    </header>

    <div
      class="grid grid-cols-1 md:grid-cols-2 gap-8 sm:gap-12 px-4 sm:px-0"
      id="posts-grid"
    >
      {
        posts.map((post) => (
          <article
            class="post-card group relative bg-gray-50 dark:bg-gray-900/40 border border-gray-200 dark:border-gray-800/60 rounded-2xl overflow-hidden hover:border-blue-500/30 transition-all hover:shadow-[0_0_40px_-10px_rgba(59,130,246,0.1)]"
            data-tags={(post.data.tags || []).join(',')}
          >
            <div class="p-6 sm:p-8 space-y-4">
              <div class="flex items-center space-x-3 text-xs font-mono text-gray-500 uppercase tracking-tighter">
                <span>
                  {new Date(post.data.pubDate).toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })}
                </span>
                <span class="w-1 h-1 bg-gray-300 dark:bg-gray-700 rounded-full" />
                <div class="flex gap-2">
                  {(post.data.tags || []).map((tag) => (
                    <span class="text-blue-600 dark:text-blue-500 font-bold uppercase tracking-wider">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
              <h2 class="text-2xl font-bold text-gray-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors leading-tight">
                <a href={`/blog/${post.slug}`}>{post.data.title}</a>
              </h2>
              <p class="text-gray-600 dark:text-gray-500 line-clamp-3 font-sans leading-relaxed">
                {post.data.description}
              </p>
              <div class="pt-6">
                <a
                  href={`/blog/${post.slug}`}
                  class="inline-flex items-center text-sm font-bold text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-white transition-all group-hover:translate-x-1"
                >
                  Read Article{' '}
                  <span class="ml-2 transition-transform group-hover:translate-x-1">
                    &rarr;
                  </span>
                </a>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>

<script>
  function setupFilters() {
    const buttons = document.querySelectorAll('.tag-filter');
    const cards = document.querySelectorAll('.post-card');

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        const selectedTag = button.getAttribute('data-tag');

        // Update button states
        buttons.forEach((btn) => {
          btn.classList.remove(
            'active',
            'bg-blue-600',
            'text-white',
            'border-blue-600'
          );
          btn.classList.add(
            'bg-white',
            'dark:bg-gray-900',
            'text-gray-600',
            'dark:text-gray-400',
            'border-gray-200',
            'dark:border-gray-800'
          );
        });

        button.classList.add(
          'active',
          'bg-blue-600',
          'text-white',
          'border-blue-600'
        );
        button.classList.remove(
          'bg-white',
          'dark:bg-gray-900',
          'text-gray-600',
          'dark:text-gray-400',
          'border-gray-200',
          'dark:border-gray-800'
        );

        // Filter cards
        cards.forEach((card) => {
          const cardTags = card.getAttribute('data-tags')?.split(',') || [];
          if (selectedTag === 'all' || cardTags.includes(selectedTag)) {
            (card as HTMLElement).style.display = 'block';
          } else {
            (card as HTMLElement).style.display = 'none';
          }
        });
      });
    });

    // Set initial active state for "All Posts"
    const allButton = document.querySelector('[data-tag="all"]');
    if (allButton) {
      allButton.classList.add('bg-blue-600', 'text-white', 'border-blue-600');
      allButton.classList.remove(
        'bg-white',
        'dark:bg-gray-900',
        'text-gray-600',
        'dark:text-gray-400',
        'border-gray-200',
        'dark:border-gray-800'
      );
    }
  }

  // Run on page load and after swaps (for View Transitions if enabled)
  setupFilters();
  document.addEventListener('astro:after-swap', setupFilters);
</script>

<style>
  .tag-filter.active {
    @apply ring-2 ring-blue-500/20 shadow-lg shadow-blue-500/10;
  }
</style>
